{
  "name": "obsidian-sample-plugin",
  "version": "1.0.0",
  "description": "This is a sample plugin for Obsidian (https://obsidian.md)",
  "keywords": [],
  "license": "MIT",
  "author": "xjiaxiang86@gmail.com",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && cp manifest.json dist/",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt:fix": "oxfmt",
    "fmt": "oxfmt --check",
    "test": "vitest run --passWithNoTests",
    "prepare": "husky",
    "rename": "node ./scripts/rename-plugin-name.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "25.6.0",
    "builtin-modules": "5.1.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "memfs": "4.57.2",
    "obsidian": "latest",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.3",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.5.3"
  },
  "packageManager": "pnpm@11.5.3"
}
